
					Jump		Start

/ Color Values
COLOR_UNKNOWN,		HEX			2108 / Dark Gray
COLOR_FLAG,			HEX			7FE0 / Yellow
COLOR_MINE,			HEX			0000 / Black
COLOR_ZERO,			HEX			6318 / Light Gray
COLOR_ONE,			HEX			01FF / Blue
COLOR_TWO,			HEX			03E0 / Green
COLOR_THREE,		HEX			7C00 / Red
COLOR_FOUR,			HEX			0010 / Dark Blue
COLOR_FIVE,			HEX			4000 / Dark Red
COLOR_SIX,			HEX			03FF / Cyan
COLOR_SEVEN,		HEX			501F / Purple
COLOR_EIGHT,		HEX			DFFF / White

